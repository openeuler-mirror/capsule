# Slidea model routing mode:
# - ECONOMIC: all text calls use DEFAULT_LLM, all vision calls use DEFAULT_VLM
# - PREMIUM: only premium-routed callsites use PREMIUM_LLM first, then fall back to default models on failure
SLIDEA_MODE=ECONOMIC

# Required: default text model for the main pipeline.
# Current implementation uses langchain_openai ChatOpenAI, so these
# settings currently support OpenAI-compatible APIs only.
DEFAULT_LLM_MODEL=
DEFAULT_LLM_API_KEY=
DEFAULT_LLM_API_BASE_URL=

# Optional: premium multimodal model for premium-routed callsites.
# Please avoid changing the default base_url and model_name unless you
# know exactly what you are doing. The only recommended premium model
# right now is `google/gemini-3.1-pro-preview`; in most cases you only
# need to fill in PREMIUM_LLM_API_KEY.
PREMIUM_LLM_MODEL=google/gemini-3.1-pro-preview
PREMIUM_LLM_API_KEY=
PREMIUM_LLM_API_BASE_URL=https://openrouter.ai/api/v1

# Optional: default vision model for image/page analysis.
# Current implementation also uses langchain_openai ChatOpenAI here,
# so these settings currently support OpenAI-compatible APIs only.
DEFAULT_VLM_MODEL=
DEFAULT_VLM_API_KEY=
DEFAULT_VLM_API_BASE_URL=
# Image payload mode sent to the VLM: data_url or raw_base64
VLM_IMAGE_INPUT_MODE=data_url

# Optional: embeddings for deep research ranking.
# Current implementation uses langchain_openai OpenAIEmbeddings, so these
# settings currently support OpenAI-compatible APIs only.
# Leave these empty and set DISABLE_EMBEDDING=true if you do not want
# embedding-based retrieval.
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
EMBEDDING_API_BASE_URL=
DISABLE_EMBEDDING=false

# Optional: Tavily web search
# Format requirement for TAVILY_API_KEYS:
# - Use a single-quoted JSON array string.
# - Each item must be a Tavily API key string.
# - Example:
#   TAVILY_API_KEYS='["tvly-xxx","tvly-yyy"]'
# - Use '[]' to disable Tavily search or leave it without configured keys.
TAVILY_API_KEYS='[]'

# Optional: image generation.
# IMAGE_GEN_PROVIDER supports:
# - api: call a remote HTTP API with payload {prompt,width,height} and
#   expect response.files[0].url in the response JSON. This is a project-
#   specific integration contract and should not be assumed to match any
#   official provider protocol directly.
# - comfyui_local: use a local ComfyUI workflow instead of a remote API.
IMAGE_GEN_PROVIDER=api
IMG_GEN_MODEL=
IMG_GEN_API_KEY=
IMG_GEN_API_BASE_URL=

# Optional: local ComfyUI image generation
COMFYUI_URL=
COMFYUI_WORKFLOW=
COMFYUI_PROMPT_UTILS_PATH=
COMFYUI_CLI_PATH=
COMFYUI_PYTHON_BIN=

# Optional: image search / pipeline toggles
USE_WEB_IMG_SEARCH=true
USE_CACHE=true
RESEARCH_MODE_FORCE=
